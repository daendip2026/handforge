# Copy this file to .env and adjust values as needed.
# .env is gitignored. .env.example is committed.

# Pattern: HANDFORGE__<SECTION>__<KEY>

# --- Global ---
# HANDFORGE__CONFIG_PATH=config.yaml

# --- Camera ---
# HANDFORGE__CAMERA__INDEX=0
# HANDFORGE__CAMERA__WIDTH=640
# HANDFORGE__CAMERA__HEIGHT=480

# --- MediaPipe ---
# HANDFORGE__MEDIAPIPE__MIN_DETECTION_CONFIDENCE=0.7
# HANDFORGE__MEDIAPIPE__MODEL_COMPLEXITY=1  # Required: 1 (Full) for world_landmarks

# --- Output ---
# Mode options: websocket | osc | console | none
# HANDFORGE__OUTPUT__MODE=websocket
# HANDFORGE__OUTPUT__WEBSOCKET__PORT=8080
# HANDFORGE__OUTPUT__OSC__PORT=9000

# --- Logging ---
# HANDFORGE__LOGGING__LEVEL=DEBUG
# HANDFORGE__LOGGING__CONSOLE_ENABLED=true
